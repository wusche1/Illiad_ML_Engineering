
# Ignore lecture build outputs (except PDFs)
lectures/*/output/*
!lectures/*/output/slides.pdf

# Ignore all PDF files in bib folder
bib/**/*.pdf

# Ignore HTML snapshots
bib/**/*.html

# Ignore Zotero sync log
bib/.sync_log.txt

# ignore embeddings
embeddings/

# Ignore python env
.venv/

# ignore chapters
bib/*/chapters/

.secrets
*.out
sync.log

# Ignore cloned experiment repos (contents only, keep the folder)
experiments/**

# Jupyter checkpoints
.ipynb_checkpoints/
